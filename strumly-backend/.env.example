# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/strumly_db

# Server
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# Bcrypt
BCRYPT_ROUNDS=10

# Email (Gmail SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
